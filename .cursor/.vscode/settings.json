       "version": "0.2.0",
    "configurations": [
        {
            "type": "lua",
            "request": "launch",
            "name": "Debug",
            "program": "${workspaceFolder}/test/Test.lua"
        }
    ],
    "stylua.targetReleaseVersion": "latest",
    "githubPullRequests.ignoredPullRequestBranches": [
        "main"
    ],
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.lua$",
                "isAsync": true,
                "cmd": "${workspaceFolder}/BundleAndDeploy.bat"
            }
        ]
    }
}