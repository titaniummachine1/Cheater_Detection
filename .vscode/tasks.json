{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bundle and deploy (lua)",
      "type": "shell",
      "command": "${workspaceFolder}/BundleAndDeploy.bat",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Bundle and deploy (npm)",
      "type": "shell",
      "command": "npm run bundle-deploy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Watch and auto-deploy",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}