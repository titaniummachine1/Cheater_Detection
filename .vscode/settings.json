{
  "Lua.runtime.version": "Lua 5.4",
  "code-runner.executorMap": {
    "python": "py -3 -u"
  },
  "code-runner.runInTerminal": true,
  "Lua.workspace.library": [
    "C:/gitProjects/Lmaobox-Annotations/library"
  ],
  "Lua.workspace.checkThirdParty": true,
  "files.autoSave": "onFocusChange",
  "achilleshr.runonsave": {
    "autoSave": true,
    "onSave": true,
    "commands": [
      {
        "match": ".*\\.lua$",
        "isAsync": false,
        "cmd": "\"${workspaceFolder}\\BundleAndDeploy.bat\"",
        "autoShowOutputPanel": "always"
      }
    ]
  },
  "emeraldwalk.runonsave": {
    "autoSave": true,
    "commands": [
      {
        "match": ".*\\.lua$",
        "isAsync": false,
        "cmd": "\"${workspaceFolder}\\BundleAndDeploy.bat\"",
        "autoShowOutputPanel": "always"
      }
    ]
  }
}